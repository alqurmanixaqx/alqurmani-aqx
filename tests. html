<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>موسوعة الأدباء والشعراء AQX</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@700;900&family=Tajawal:wght@500;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --b-dark: #120002;
            --b-mid: #380209;
            --b-light: #5c0511;
            --g-light: #ffd700;
            --g-glow: rgba(212, 175, 55, 0.4);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
            -webkit-user-select: none;
        }

        html, body {
            overflow-x: hidden;
            overflow-y: auto;
            background-color: var(--b-dark);
            font-family: 'Tajawal', sans-serif;
            color: #fff;
            min-height: 100vh;
        }

        body {
            background: linear-gradient(135deg, var(--b-dark) 0%, #1f0105 50%, var(--b-mid) 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            padding-bottom: 140px;
        }

        .rainbow-snake-border {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            border: 5px solid transparent;
            border-image: linear-gradient(45deg, #ff0040, #ff8000, #ff00ff, #ffcc00, #ff0055, #ff3300, #ff0040) 1;
            pointer-events: none;
            z-index: 9999;
            filter: drop-shadow(0 0 10px rgba(255, 0, 85, 0.6));
            animation: bShift 8s linear infinite;
        }

        @keyframes bShift {
            0% { filter: hue-rotate(0deg) drop-shadow(0 0 8px #ff0055); }
            50% { filter: hue-rotate(180deg) drop-shadow(0 0 15px #ffcc00); }
            100% { filter: hue-rotate(360deg) drop-shadow(0 0 8px #ff0055); }
        }

        #gold-particle-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 1;
            pointer-events: none;
        }

        .top-vacuum-space {
            height: clamp(240px, 35vh, 380px);
            width: 100%;
            position: relative;
            z-index: 2;
        }

        .main-content-hub {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 1100px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 45px;
            padding: 0 24px;
        }

        .neon-master-title {
            font-family: 'Cairo', sans-serif;
            font-size: clamp(1.8rem, 4.5vw, 3.6rem);
            font-weight: 900;
            text-align: center;
            animation: nColors 10s infinite linear, tFloat 3.5s ease-in-out infinite alternate;
        }

        @keyframes tFloat {
            0% { transform: translateY(0); }
            100% { transform: translateY(-10px); }
        }

        @keyframes nColors {
            0%, 100% { color: #fff; text-shadow: 0 0 15px #ff0055, 0 0 30px #ff0055, 0 0 45px #ffd700; }
            25% { color: #ffd700; text-shadow: 0 0 15px #ffd700, 0 0 30px #ff3300, 0 0 45px #ff00ff; }
            50% { color: #fff; text-shadow: 0 0 15px #ff00ff, 0 0 30px #ff0040, 0 0 45px #ffcc00; }
            75% { color: #ffcc00; text-shadow: 0 0 15px #ff3300, 0 0 30px #ff0055, 0 0 45px #fff; }
        }

        .ad-luxury-box {
            background: rgba(56, 2, 9, 0.4);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border-radius: 16px;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
            margin: 10px 0;
            width: fit-content;
            max-width: 100%;
        }

        .ad-banner-top {
            width: 320px;
            height: 50px;
        }

        .ad-square-middle {
            width: 300px;
            height: 250px;
            margin: 20px auto;
        }

        .luxury-sections-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 35px;
            width: 100%;
        }

        .luxury-card-portal {
            background: linear-gradient(135deg, rgba(92, 5, 17, 0.3) 0%, rgba(18, 0, 2, 0.7) 100%);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            padding: 45px 30px;
            border-radius: 24px;
            text-decoration: none;
            color: #fff;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 18px;
            cursor: pointer;
            position: relative;
            transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
            border: none;
        }

        .luxury-card-portal::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            border-radius: 24px;
            background: radial-gradient(circle at center, rgba(255, 215, 0, 0.2) 0%, transparent 75%);
            opacity: 0;
            transition: opacity 0.5s ease;
            z-index: -1;
        }

        .luxury-card-portal:hover::before {
            opacity: 1;
        }

        .luxury-card-portal:hover {
            transform: translateY(-10px);
            box-shadow: 0 30px 60px rgba(255, 215, 0, 0.15);
        }

        .card-icon-glow {
            font-size: 3.2rem;
            filter: drop-shadow(0 0 12px var(--g-light));
            transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        
        .luxury-card-portal:hover .card-icon-glow {
            transform: scale(1.15) rotateY(360deg);
        }

        .card-main-title {
            font-size: clamp(1.3rem, 2vw, 1.75rem);
            font-weight: 900;
            text-shadow: 0 0 10px rgba(255,255,255,0.2);
            transition: color 0.3s ease;
        }
        
        .luxury-card-portal:hover .card-main-title {
            color: var(--g-light);
            text-shadow: 0 0 15px var(--g-light);
        }

        .card-description-text {
            font-size: clamp(0.95rem, 1.2vw, 1.05rem);
            color: #f7e6e8;
            line-height: 1.8;
            font-weight: 500;
        }

        .luxury-video-cinema-wrap {
            width: 100%;
            max-width: 760px;
            background: linear-gradient(135deg, rgba(9c, 5, 17, 0.2) 0%, rgba(56, 2, 9, 0.5) 100%);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: 24px;
            padding: 16px;
            box-shadow: 0 25px 55px rgba(0, 0, 0, 0.7), 0 0 30px rgba(255, 0, 85, 0.1);
            margin: 20px 0;
        }

        .video-container-ratio {
            position: relative;
            width: 100%;
            padding-bottom: 56.25%;
            height: 0;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.9);
        }

        .video-container-ratio iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }

        .infinite-poetry-marquee {
            width: 100%;
            background: linear-gradient(90deg, transparent 0%, rgba(18, 0, 2, 0.95) 15%, rgba(18, 0, 2, 0.95) 85%, transparent 100%);
            padding: 20px 0;
            overflow: hidden;
            position: fixed;
            bottom: 25px;
            z-index: 100;
            pointer-events: none;
            border-top: 1px solid rgba(255, 215, 0, 0.15);
            border-bottom: 1px solid rgba(255, 215, 0, 0.15);
            box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        }

        .marquee-track-flow {
            display: inline-block;
            white-space: nowrap;
            padding-right: 100%;
            animation: sMflow 55s linear infinite;
        }

        .marquee-item-unit {
            display: inline-flex;
            align-items: center;
            gap: 15px;
            color: #ffd700;
            font-size: 1.25rem;
            font-weight: 700;
            margin-left: 120px;
            text-shadow: 0 0 12px rgba(212, 175, 55, 0.4);
        }

        .marquee-item-unit span.decor-icon {
            font-size: 1.5rem;
            filter: drop-shadow(0 0 6px #ffd700);
        }

        @keyframes sMflow {
            0% { transform: translate3d(0, 0, 0); }
            100% { transform: translate3d(-100%, 0, 0); }
        }

        @media (max-width: 850px) {
            .luxury-sections-grid {
                grid-template-columns: 1fr;
                gap: 25px;
            }
            .top-vacuum-space {
                height: 180px;
            }
            .main-content-hub {
                gap: 30px;
            }
        }
    </style>
