<title>Scroll To Top - AQX</title>
<style>

/* ===== SCROLL TO TOP BUTTON ===== */
#scroll-top-btn {
  position: fixed;
  bottom: 40px;
  left: 40px;
  z-index: 88888;
  width: 58px;
  height: 58px;
  border-radius: 50%;
  cursor: pointer;
  border: none;
  outline: none;
  background: transparent;
  padding: 0;
  opacity: 0;
  pointer-events: none;
  transform: translateY(30px);
  transition: opacity 0.45s ease, transform 0.45s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

#scroll-top-btn.visible {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}

/* الدائرة الخارجية المتحركة */
#scroll-top-btn .outer-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: conic-gradient(
    #FFD700 0deg,
    #FFF176 60deg,
    #00CDD9 120deg,
    #00B4C8 180deg,
    #FFD700 240deg,
    #FF6B6B 300deg,
    #FFD700 360deg
  );
  animation: spinRing 3s linear infinite;
  filter: drop-shadow(0 0 10px rgba(255,215,0,0.7)) drop-shadow(0 0 20px rgba(0,180,200,0.5));
}

@keyframes spinRing {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* الدائرة الداخلية */
#scroll-top-btn .inner-circle {
  position: absolute;
  inset: 4px;
  border-radius: 50%;
  background: linear-gradient(145deg, #0d1b2a, #1a2a3a);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  transition: background 0.3s ease;
}

#scroll-top-btn:hover .inner-circle {
  background: linear-gradient(145deg, #001a22, #003344);
}

/* السهم SVG */
#scroll-top-btn .arrow-svg {
  width: 24px;
  height: 24px;
  transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  filter: drop-shadow(0 0 6px rgba(255,215,0,0.9));
  position: relative;
  z-index: 3;
}

/* لما يدوس: يتشقلب */
#scroll-top-btn.flipping .arrow-svg {
  transform: rotate(360deg) scale(1.3);
}

/* حلقات النبض */
#scroll-top-btn .pulse-ring {
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  border: 2px solid rgba(255, 215, 0, 0.6);
  animation: pulseExpand 2s ease-out infinite;
  pointer-events: none;
}
#scroll-top-btn .pulse-ring:nth-child(2) {
  animation-delay: 0.7s;
  border-color: rgba(0, 200, 220, 0.4);
}
#scroll-top-btn .pulse-ring:nth-child(3) {
  animation-delay: 1.4s;
  border-color: rgba(255, 215, 0, 0.25);
}

@keyframes pulseExpand {
  0%   { transform: scale(1); opacity: 0.8; }
  100% { transform: scale(2.2); opacity: 0; }
}

/* جزيئات ذهبية تنطلق عند الضغط */
.spark {
  position: fixed;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  pointer-events: none;
  z-index: 99999;
  animation: sparkFly 0.8s ease-out forwards;
}
@keyframes sparkFly {
  0%   { transform: translate(0,0) scale(1); opacity: 1; }
  100% { transform: translate(var(--tx), var(--ty)) scale(0); opacity: 0; }
}

/* Progress ring حول الزر */
#scroll-progress-ring {
  position: fixed;
  bottom: 33px;
  left: 33px;
  width: 72px;
  height: 72px;
  z-index: 88887;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.45s ease;
  transform: rotate(-90deg);
}
#scroll-progress-ring.visible { opacity: 1; }
#scroll-progress-ring circle {
  fill: none;
  stroke: rgba(255,215,0,0.25);
  stroke-width: 2;
}
#scroll-progress-ring .progress-arc {
  stroke: #FFD700;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-dasharray: 220;
  stroke-dashoffset: 220;
  filter: drop-shadow(0 0 4px #FFD700);
  transition: stroke-dashoffset 0.1s linear;
}

/* تلميح نص */
#scroll-top-btn::after {
  content: 'للأعلى';
  position: absolute;
  bottom: -26px;
  left: 50%;
  transform: translateX(-50%);
  font-family: 'Cairo', sans-serif;
  font-size: 10px;
  font-weight: 700;
  color: rgba(255,215,0,0.75);
  white-space: nowrap;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
  letter-spacing: 1px;
  text-shadow: 0 0 8px rgba(255,215,0,0.5);
}
#scroll-top-btn.visible:hover::after { opacity: 1; }

