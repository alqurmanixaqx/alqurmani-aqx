<button id="scroll-top-btn" onclick="scrollToTopAction()" title="للأعلى">
  <span class="pulse-ring"></span>
  <span class="pulse-ring"></span>
  <span class="pulse-ring"></span>
  <div class="outer-ring"></div>
  <div class="inner-circle">
    <svg class="arrow-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="arrowGrad" x1="12" y1="20" x2="12" y2="4" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#FFC107"/>
          <stop offset="50%" stop-color="#FFD700"/>
          <stop offset="100%" stop-color="#FFF176"/>
        </linearGradient>
      </defs>
      <!-- السهم: خط رأسي + رأس السهم -->
      <line x1="12" y1="20" x2="12" y2="5" stroke="url(#arrowGrad)" stroke-width="2.5" stroke-linecap="round"/>
      <polyline points="6,11 12,4 18,11" stroke="url(#arrowGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
