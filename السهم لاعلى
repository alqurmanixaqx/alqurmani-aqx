<script>
// ===== AUDIO =====
let _audioCtx = null;
function _getAudio() {
  if (!_audioCtx) _audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  return _audioCtx;
}

function playScrollUp() {
  const ctx = _getAudio();
  // نغمة صعود موسيقية راقية
  const notes = [523, 659, 784, 1047]; // C5, E5, G5, C6
  notes.forEach((freq, i) => {
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    const t = ctx.currentTime + i * 0.07;
    osc.type = 'sine';
    osc.frequency.setValueAtTime(freq, t);
    gain.gain.setValueAtTime(0, t);
    gain.gain.linearRampToValueAtTime(0.18, t + 0.03);
    gain.gain.exponentialRampToValueAtTime(0.001, t + 0.25);
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.start(t);
    osc.stop(t + 0.26);
  });
  // whoosh هواء
  const bufSize = ctx.sampleRate * 0.4;
  const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
  const data = buf.getChannelData(0);
  for (let i = 0; i < bufSize; i++) {
    data[i] = (Math.random() * 2 - 1) * (1 - i / bufSize) * 0.12;
  }
  const src = ctx.createBufferSource();
  src.buffer = buf;
  const filt = ctx.createBiquadFilter();
  filt.type = 'highpass';
  filt.frequency.value = 1200;
  const g2 = ctx.createGain();
  g2.gain.setValueAtTime(0.5, ctx.currentTime);
  g2.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.4);
  src.connect(filt); filt.connect(g2); g2.connect(ctx.destination);
  src.start();
}

// ===== SPARKS =====
function launchSparks(btn) {
  const rect = btn.getBoundingClientRect();
  const cx = rect.left + rect.width / 2;
  const cy = rect.top + rect.height / 2;
  const colors = ['#FFD700','#FFF176','#00CDD9','#FF6B6B','#FFC107','#ffffff'];
  for (let i = 0; i < 14; i++) {
    const spark = document.createElement('div');
    spark.classList.add('spark');
    const angle = (i / 14) * Math.PI * 2;
    const dist = 50 + Math.random() * 50;
    spark.style.cssText = `
      left: ${cx - 3}px;
      top: ${cy - 3}px;
      background: ${colors[i % colors.length]};
      --tx: ${Math.cos(angle) * dist}px;
      --ty: ${Math.sin(angle) * dist}px;
      box-shadow: 0 0 6px ${colors[i % colors.length]};
    `;
    document.body.appendChild(spark);
    setTimeout(() => spark.remove(), 850);
  }
}

// ===== SCROLL ACTION =====
function scrollToTopAction() {
  const btn = document.getElementById('scroll-top-btn');

  // تشقلب
  btn.classList.add('flipping');
  setTimeout(() => btn.classList.remove('flipping'), 550);

  // صوت
  playScrollUp();

  // شرر
  launchSparks(btn);

  // انتقال ناعم للأعلى
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ===== SHOW / HIDE ON SCROLL + PROGRESS =====
const progressArc = document.querySelector('#scroll-progress-ring .progress-arc');
const circumference = 2 * Math.PI * 34; // r=34 → ~213.6
progressArc.style.strokeDasharray = circumference;
progressArc.style.strokeDashoffset = circumference;

window.addEventListener('scroll', () => {
  const btn   = document.getElementById('scroll-top-btn');
  const ring  = document.getElementById('scroll-progress-ring');
  const scrolled = window.scrollY;
  const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
  const pct = maxScroll > 0 ? scrolled / maxScroll : 0;

  if (scrolled > 280) {
    btn.classList.add('visible');
    ring.classList.add('visible');
  } else {
    btn.classList.remove('visible');
    ring.classList.remove('visible');
  }

  // تحديث حلقة التقدم
  const offset = circumference - pct * circumference;
  progressArc.style.strokeDashoffset = offset;
}, { passive: true });
</script>

