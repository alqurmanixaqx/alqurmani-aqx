function r(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }  
function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }  
  
// ===== أوديو =====  
let _cmAudio = null;  
function _cmGetAudio() {  
  if (!_cmAudio) _cmAudio = new (window.AudioContext || window.webkitAudioContext)();  
  return _cmAudio;  
}  
  
function cmPlayPour() {  
  const ctx = _cmGetAudio();  
  // صوت صب القهوة (ضجيج مفلتر + قرقرة)  
  const dur = 1.8;  
  const bufSize = Math.floor(ctx.sampleRate * dur);  
  const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);  
  const data = buf.getChannelData(0);  
  for (let i = 0; i < bufSize; i++) {  
    const t = i / ctx.sampleRate;  
    // ضجيج صب  
    data[i] = (Math.random() * 2 - 1) * 0.35 * Math.pow(Math.sin(Math.PI * t / dur), 0.4);  
    // قرقرة خفيفة  
    data[i] += Math.sin(2 * Math.PI * 180 * t) * 0.04 * Math.exp(-t * 2);  
    data[i] += Math.sin(2 * Math.PI * 240 * t) * 0.03 * Math.exp(-t * 3);  
  }  
  const src = ctx.createBufferSource();  
  src.buffer = buf;  
  // فلتر لصوت قهوة  
  const lp = ctx.createBiquadFilter();  
  lp.type = 'lowpass';  
  lp.frequency.value = 900;  
  const hp = ctx.createBiquadFilter();  
  hp.type = 'highpass';  
  hp.frequency.value = 150;  
  const gain = ctx.createGain();  
  gain.gain.setValueAtTime(0.0, ctx.currentTime);  
  gain.gain.linearRampToValueAtTime(0.6, ctx.currentTime + 0.15);  
  gain.gain.setValueAtTime(0.6, ctx.currentTime + dur - 0.4);  
  gain.gain.linearRampToValueAtTime(0.0, ctx.currentTime + dur);  
  src.connect(hp); hp.connect(lp); lp.connect(gain); gain.connect(ctx.destination);  
  src.start();  
  src.stop(ctx.currentTime + dur);  
  
  // نغمة بدء قهوة  
  const osc = ctx.createOscillator();  
  const og = ctx.createGain();  
  osc.type = 'sine';  
  osc.frequency.setValueAtTime(440, ctx.currentTime);  
  osc.frequency.exponentialRampToValueAtTime(220, ctx.currentTime + 0.5);  
  og.gain.setValueAtTime(0.15, ctx.currentTime);  
  og.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.5);  
  osc.connect(og); og.connect(ctx.destination);  
  osc.start(); osc.stop(ctx.currentTime + 0.5);  
}  
  
function cmPlayDing() {  
  const ctx = _cmGetAudio();  
  const freqs = [784, 988, 1175];  
  freqs.forEach((f, i) => {  
    const osc = ctx.createOscillator();  
    const g = ctx.createGain();  
    const t = ctx.currentTime + i * 0.12;  
    osc.type = 'triangle';  
    osc.frequency.value = f;  
    g.gain.setValueAtTime(0.12, t);  
    g.gain.exponentialRampToValueAtTime(0.001, t + 0.4);  
    osc.connect(g); g.connect(ctx.destination);  
    osc.start(t); osc.stop(t + 0.45);  
  });  
}  
  
function cmPlayOpen() {  
  const ctx = _cmGetAudio();  
  const osc = ctx.createOscillator();  
  const g = ctx.createGain();  
  osc.type = 'sine';  
  osc.frequency.setValueAtTime(330, ctx.currentTime);  
  osc.frequency.exponentialRampToValueAtTime(660, ctx.currentTime + 0.3);  
  g.gain.setValueAtTime(0.12, ctx.currentTime);  
  g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.35);  
  osc.connect(g); g.connect(ctx.destination);  
  osc.start(); osc.stop(ctx.currentTime + 0.36);  
}  
  
// ===== فتح / إغلاق =====  
function cmToggle() {  
  const card = document.getElementById('cm-card');  
  if (card.classList.contains('open')) { cmClose(); }  
  else {  
    card.classList.add('open');  
    document.getElementById('cm-overlay').classList.add('active');  
    cmPlayOpen();  
    // توليد أول مرة إذا لم تتولد  
    if (!window._cmGenerated) { cmGenerate(); window._cmGenerated = true; }  
  }  
}  
function cmClose() {  
  document.getElementById('cm-card').classList.remove('open');  
  document.getElementById('cm-overlay').classList.remove('active');  
}  
  
// ===== توليد البيانات =====  
function cmGenerate() {  
  const genius  = r(1, 100);  
  const create  = r(1, 100);  
  const focus   = r(1, 100);  
  const luck    = r(1, 100);  
  const crazy   = r(1, 100);  
  const cups    = r(1, 10);  
  const coffee  = pick(CM_DATA.coffees);  
  const tip     = pick(CM_DATA.tips);  
  const predict = pick(CM_DATA.predictions);  
  const badge   = pick(CM_DATA.badges);  
  
  // حالة الجنون  
  const crazyState = CM_DATA.crazyStates.find(s => crazy <= s.max) || CM_DATA.crazyStates[CM_DATA.crazyStates.length-1];  
  
  // تطبيق القيم  
  function setVal(id, val) {  
    const el = document.getElementById(id);  
    if (el) el.textContent = val;  
  }  
  function setBar(id, pct) {  
    const el = document.getElementById(id);  
    if (el) setTimeout(() => { el.style.width = pct + '%'; }, 100);  
  }  
  
  setVal('val-genius', genius);   setBar('bar-genius', genius);  
  setVal('val-create', create);   setBar('bar-create', create);  
  setVal('val-focus',  focus);    setBar('bar-focus',  focus);  
  setVal('val-luck',   luck);     setBar('bar-luck',   luck);  
  setVal('val-crazy',  crazy);    setBar('bar-crazy',  crazy);  
  setVal('val-coffee', coffee);  
  setVal('val-tip',    tip);  
  setVal('val-predict', predict);  
  setVal('val-badge',  badge);  
  
  // حالة الجنون  
  const stateEl = document.getElementById('val-crazy-state');  
  if (stateEl) {  
    stateEl.textContent = crazyState.label;  
    stateEl.className = 'cm-crazy-state ' + crazyState.cls;  
  }  
  
  // أكواب القهوة  
  const cupsRow = document.getElementById('val-cups-row');  
  const cupsCount = document.getElementById('val-cups-count');  
  if (cupsRow) {  
    cupsRow.innerHTML = '';  
    for (let i = 0; i < cups; i++) {  
      const cup = document.createElement('span');  
      cup.className = 'cm-cup';  
      cup.textContent = '☕';  
      cup.style.animationDelay = (i * 0.08) + 's';  
      cupsRow.appendChild(cup);  
    }  
  }  
  if (cupsCount) cupsCount.textContent = `عدد الأكواب المقترحة: ${cups} كوب`;  
  setBar('bar-cups', cups * 10);  
  
  // وقت التحديث  
  const now = new Date();  
  const timeStr = now.toLocaleTimeString('ar-EG', {hour:'2-digit', minute:'2-digit'});  
  setVal('cm-last-update', `⏱ آخر تحديث: ${timeStr}`);  
  
  // أنيميشن على البطاقات  
  document.querySelectorAll('.cm-item').forEach((item, i) => {  
    item.classList.remove('refreshing');  
    setTimeout(() => item.classList.add('refreshing'), i * 50);  
  });  
}  
  
// ===== زر الجرعة الجديدة =====  
function cmRefresh() {  
  const btn = document.getElementById('cm-refresh-btn');  
  const icon = document.getElementById('refresh-icon');  
  btn.classList.add('spinning');  
  btn.disabled = true;  
  
  // صوت صب القهوة  
  cmPlayPour();  
  
  // إعادة توليد بعد انيميشن  
  setTimeout(() => {  
    cmGenerate();  
    cmPlayDing();  
    btn.classList.remove('spinning');  
    btn.disabled = false;  
  }, 700);  
}  
  
// ===== توليد عند الفتح =====  
window._cmGenerated = false;  
  
// ===== التحديث التلقائي كل 30 دقيقة =====  
setInterval(() => {  
  cmGenerate();  
}, 30 * 60 * 1000);  
  
// ===== توليد عند تحميل الصفحة =====  
window.addEventListener('DOMContentLoaded', () => {  
  cmGenerate();  
  window._cmGenerated = true;  
});  
