<!DOCTYPE html>  <html lang="ar" dir="rtl">  
<head>  
<meta charset="UTF-8">  
<meta name="viewport" content="width=device-width, initial-scale=1.0">  
<title>ماكينة القهوة الذكية AQX</title>  
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">  
<style>  /* =============================================
ماكينة القهوة الذكية AQX
ضع هذا الكود في أي ملف HTML
الموضع: أقصى يسار الصفحة أعلى (fixed)
============================================= */

{ margin: 0; padding: 0; box-sizing: border-box; }


body {
font-family: 'Cairo', sans-serif;
background: #f5f5f5;
min-height: 200vh;
direction: rtl;
}

/* ===== زر الفتح (أيقونة القهوة الثابتة) ===== /
#cm-toggle {
position: fixed;
top: 18px;
right: 18px; / ← غيّره إلى left: 18px في ملفاتك الحقيقية */
z-index: 77777;
width: 52px;
height: 52px;
border-radius: 14px;
background: linear-gradient(145deg, #1a0a00, #3d1a00);
border: 2px solid #8B4513;
cursor: pointer;
display: flex;
align-items: center;
justify-content: center;
box-shadow: 0 4px 20px rgba(139,69,19,0.5), 0 0 0 0 rgba(255,215,0,0.4);
animation: cmPulseBtn 3s infinite;
transition: transform 0.2s ease;
}
#cm-toggle:hover { transform: scale(1.1) rotate(-5deg); }
@keyframes cmPulseBtn {
0%,100% { box-shadow: 0 4px 20px rgba(139,69,19,0.5), 0 0 0 0 rgba(255,215,0,0.4); }
50%      { box-shadow: 0 4px 28px rgba(139,69,19,0.7), 0 0 0 8px rgba(255,215,0,0); }
}
#cm-toggle svg { width: 28px; height: 28px; }

/* نقطة حمراء للتنبيه */
#cm-toggle::after {
content: '☕';
font-size: 22px;
}

/* ===== البطاقة الرئيسية ===== */
#cm-card {
position: fixed;
top: 0;
left: -400px;
width: 360px;
max-height: 100vh;
z-index: 77776;
transition: left 0.5s cubic-bezier(0.23, 1, 0.32, 1);
overflow: hidden;
display: flex;
flex-direction: column;
}
#cm-card.open { left: 0; }

/* خلفية البطاقة: ماكينة قهوة داكنة فاخرة */
.cm-body {
background: linear-gradient(170deg, #1C0A00 0%, #2D1200 25%, #1a0800 50%, #0d0400 100%);
border-left: none;
border-right: 3px solid #8B4513;
border-top: none;
border-bottom: none;
height: 100vh;
overflow-y: auto;
overflow-x: hidden;
scrollbar-width: thin;
scrollbar-color: #8B4513 #1C0A00;
position: relative;
}
.cm-body::-webkit-scrollbar { width: 5px; }
.cm-body::-webkit-scrollbar-track { background: #1C0A00; }
.cm-body::-webkit-scrollbar-thumb { background: linear-gradient(180deg, #FFD700, #8B4513); border-radius: 10px; }

/* ===== شبكة المعدن في الخلفية ===== */
.cm-body::before {
content: '';
position: absolute;
inset: 0;
background-image:
repeating-linear-gradient(0deg, rgba(255,255,255,0.015) 0px, rgba(255,255,255,0.015) 1px, transparent 1px, transparent 20px),
repeating-linear-gradient(90deg, rgba(255,255,255,0.015) 0px, rgba(255,255,255,0.015) 1px, transparent 1px, transparent 20px);
pointer-events: none;
z-index: 0;
}

/* ===== رسم ماكينة القهوة SVG ===== */
.cm-machine-art {
display: flex;
justify-content: center;
align-items: center;
padding: 18px 0 8px;
position: relative;
z-index: 2;
}

/* ===== رأس البطاقة ===== */
.cm-header {
padding: 6px 16px 14px;
text-align: center;
position: relative;
z-index: 2;
border-bottom: 1px solid rgba(139,69,19,0.4);
}
.cm-title {
font-size: 15px;
font-weight: 900;
letter-spacing: 1.5px;
background: linear-gradient(90deg, #FFD700, #FFF176, #FFD700);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
animation: cmTitleGlow 3s infinite;
background-size: 200% 100%;
}
@keyframes cmTitleGlow {
0%,100% { background-position: 0% 0%; }
50%      { background-position: 100% 0%; }
}
.cm-subtitle {
font-size: 10px;
color: rgba(255,200,120,0.65);
font-weight: 400;
margin-top: 2px;
letter-spacing: 0.5px;
}

/* ===== بخار القهوة المتحرك ===== */
.cm-steam-wrap {
display: flex;
justify-content: center;
gap: 6px;
margin-bottom: 6px;
position: relative;
z-index: 2;
}
.cm-steam {
width: 4px;
border-radius: 4px;
background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.5) 50%, rgba(255,255,255,0) 100%);
animation: steamRise 2.5s ease-in-out infinite;
}
.cm-steam:nth-child(1) { height: 22px; animation-delay: 0s; }
.cm-steam:nth-child(2) { height: 32px; animation-delay: 0.4s; }
.cm-steam:nth-child(3) { height: 18px; animation-delay: 0.8s; }
.cm-steam:nth-child(4) { height: 28px; animation-delay: 1.2s; }
@keyframes steamRise {
0%   { transform: translateY(0) scaleX(1); opacity: 0; }
30%  { opacity: 0.8; }
100% { transform: translateY(-30px) scaleX(1.5); opacity: 0; }
}

/* ===== شريط الزمن (آخر تحديث) ===== */
.cm-last-update {
text-align: center;
font-size: 9.5px;
color: rgba(255,180,80,0.5);
margin: 0 0 8px;
position: relative;
z-index: 2;
letter-spacing: 0.5px;
}

/* ===== محتوى البطاقات ===== */
.cm-content {
padding: 6px 14px 16px;
position: relative;
z-index: 2;
display: flex;
flex-direction: column;
gap: 8px;
}

/* بطاقة واحدة */
.cm-item {
background: rgba(255,255,255,0.04);
border: 1px solid rgba(139,69,19,0.3);
border-radius: 12px;
padding: 10px 12px;
position: relative;
overflow: hidden;
transition: border-color 0.3s ease, background 0.3s ease;
}
.cm-item:hover {
border-color: rgba(255,215,0,0.4);
background: rgba(255,255,255,0.07);
}
.cm-item::before {
content: '';
position: absolute;
top: 0; right: 0;
width: 3px; height: 100%;
background: linear-gradient(180deg, #FFD700, #8B4513);
border-radius: 0 12px 12px 0;
}

.cm-item-label {
font-size: 10px;
color: rgba(255,180,80,0.7);
font-weight: 600;
letter-spacing: 0.8px;
margin-bottom: 4px;
text-transform: uppercase;
}
.cm-item-value {
font-size: 13.5px;
font-weight: 700;
color: #FFF5E0;
display: flex;
align-items: center;
gap: 7px;
flex-wrap: wrap;
}
.cm-item-value .emoji-icon { font-size: 16px; flex-shrink: 0; }

/* شريط التقدم */
.cm-bar-wrap {
margin-top: 6px;
height: 5px;
background: rgba(255,255,255,0.08);
border-radius: 10px;
overflow: hidden;
}
.cm-bar-fill {
height: 100%;
border-radius: 10px;
transition: width 1.2s cubic-bezier(0.34, 1.56, 0.64, 1);
position: relative;
}
.cm-bar-fill::after {
content: '';
position: absolute;
top: 0; right: 0;
width: 8px; height: 100%;
background: rgba(255,255,255,0.6);
border-radius: 10px;
filter: blur(2px);
}

/* ألوان الأشرطة */
.bar-genius  { background: linear-gradient(90deg, #4FC3F7, #0288D1); }
.bar-create  { background: linear-gradient(90deg, #CE93D8, #8E24AA); }
.bar-focus   { background: linear-gradient(90deg, #80CBC4, #00796B); }
.bar-luck    { background: linear-gradient(90deg, #A5D6A7, #2E7D32); }
.bar-crazy   { background: linear-gradient(90deg, #FF8A65, #E64A19); }
.bar-cups    { background: linear-gradient(90deg, #FFCC02, #8B4513); }

/* حالة الجنون */
.cm-crazy-state {
display: inline-block;
margin-right: 6px;
font-size: 10px;
padding: 2px 8px;
border-radius: 20px;
font-weight: 700;
letter-spacing: 0.5px;
}
.state-normal  { background: rgba(76,175,80,0.2);  color: #A5D6A7; border: 1px solid rgba(76,175,80,0.3); }
.state-good    { background: rgba(3,169,244,0.2);  color: #81D4FA; border: 1px solid rgba(3,169,244,0.3); }
.state-creative{ background: rgba(156,39,176,0.2); color: #CE93D8; border: 1px solid rgba(156,39,176,0.3); }
.state-danger  { background: rgba(255,87,34,0.2);  color: #FF8A65; border: 1px solid rgba(255,87,34,0.3); }
.state-genius  { background: rgba(255,215,0,0.2);  color: #FFD700; border: 1px solid rgba(255,215,0,0.4); }

/* أكواب القهوة المرسومة */
.cm-cups-row {
display: flex;
gap: 4px;
flex-wrap: wrap;
margin-top: 4px;
}
.cm-cup {
font-size: 16px;
transition: transform 0.3s ease;
animation: cupBounce 0.5s ease both;
}
.cm-cup:hover { transform: scale(1.3) rotate(-10deg); }
@keyframes cupBounce {
0%   { transform: scale(0) rotate(-30deg); opacity: 0; }
70%  { transform: scale(1.2) rotate(5deg); }
100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

/* نصيحة وتوقع */
.cm-tip-text {
font-size: 12px;
color: #FFE0B2;
line-height: 1.7;
font-weight: 500;
}

/* اللقب */
.cm-title-badge {
display: inline-block;
background: linear-gradient(135deg, #8B4513, #5D2E06);
border: 1px solid #FFD700;
border-radius: 20px;
padding: 4px 14px;
font-size: 13px;
font-weight: 700;
color: #FFD700;
text-shadow: 0 0 8px rgba(255,215,0,0.6);
box-shadow: 0 0 12px rgba(255,215,0,0.2);
letter-spacing: 1px;
}

/* قهوة اليوم */
.cm-coffee-badge {
display: inline-flex;
align-items: center;
gap: 8px;
background: linear-gradient(135deg, rgba(139,69,19,0.3), rgba(93,46,6,0.4));
border: 1px solid rgba(255,215,0,0.35);
border-radius: 12px;
padding: 6px 14px;
font-size: 14px;
font-weight: 700;
color: #FFE0B2;
margin-top: 4px;
}

/* ===== زر الجرعة الجديدة ===== */
.cm-refresh-btn {
margin: 4px 14px 14px;
width: calc(100% - 28px);
padding: 12px;
border-radius: 14px;
border: none;
cursor: pointer;
font-family: 'Cairo', sans-serif;
font-size: 14px;
font-weight: 700;
letter-spacing: 1px;
background: linear-gradient(135deg, #8B4513, #5D2E06, #3d1a00);
color: #FFD700;
border: 1px solid rgba(255,215,0,0.4);
box-shadow: 0 4px 20px rgba(139,69,19,0.4), inset 0 1px 0 rgba(255,215,0,0.1);
transition: all 0.3s ease;
position: relative;
z-index: 2;
overflow: hidden;
}
.cm-refresh-btn::before {
content: '';
position: absolute;
top: -50%; left: -60%;
width: 40%; height: 200%;
background: rgba(255,255,255,0.12);
transform: skewX(-20deg);
transition: left 0.5s ease;
}
.cm-refresh-btn:hover::before { left: 130%; }
.cm-refresh-btn:hover {
background: linear-gradient(135deg, #A0522D, #6B3510, #4a2000);
box-shadow: 0 6px 28px rgba(139,69,19,0.6), 0 0 16px rgba(255,215,0,0.2);
transform: translateY(-2px);
color: #FFF176;
}
.cm-refresh-btn:active { transform: translateY(0) scale(0.98); }
.cm-refresh-btn.spinning .refresh-icon { display: inline-block; animation: spinIcon 0.6s linear; }
@keyframes spinIcon { from { transform: rotate(0); } to { transform: rotate(360deg); } }
.refresh-icon { display: inline-block; margin-left: 6px; }

/* ===== زر الإغلاق ===== */
#cm-close {
position: absolute;
top: 12px;
left: 12px;
z-index: 10;
width: 30px; height: 30px;
border-radius: 50%;
border: 1px solid rgba(255,215,0,0.4);
background: rgba(0,0,0,0.4);
color: #FFD700;
font-size: 14px;
cursor: pointer;
display: flex; align-items: center; justify-content: center;
transition: all 0.3s ease;
}
#cm-close:hover { transform: rotate(90deg); border-color: #FFD700; background: rgba(255,215,0,0.15); }

/* ===== Overlay ===== */
#cm-overlay {
position: fixed;
inset: 0;
background: rgba(0,0,0,0.35);
z-index: 77775;
opacity: 0;
pointer-events: none;
transition: opacity 0.4s ease;
}
#cm-overlay.active { opacity: 1; pointer-events: all; }

/* ===== فاصل ===== */
.cm-divider {
height: 1px;
background: linear-gradient(90deg, transparent, rgba(139,69,19,0.5), transparent);
margin: 2px 0;
position: relative;
z-index: 2;
}
.cm-divider::after {
content: '☕';
position: absolute;
left: 50%; top: 50%;
transform: translate(-50%, -50%);
font-size: 10px;
background: #1C0A00;
padding: 0 6px;
}

/* ===== أنيميشن الظهور عند التحديث ===== */
@keyframes cmItemIn {
from { opacity: 0; transform: translateX(-15px); }
to   { opacity: 1; transform: translateX(0); }
}
.cm-item.refreshing {
animation: cmItemIn 0.4s ease both;
}

/* ===== ريسبونسيف ===== */
@media (max-width: 380px) {
#cm-card { width: 100vw; }
}

/* ===== تلميح رقم الأكواب ===== */
.cm-cup-count {
font-size: 11px;
color: rgba(255,200,100,0.6);
margin-top: 3px;
font-weight: 400;
}

/* ===== مؤشر التحديث التالي ===== */
.cm-next-update {
text-align: center;
font-size: 9px;
color: rgba(139,69,19,0.7);
padding: 6px 14px 0;
position: relative;
z-index: 2;
letter-spacing: 0.5px;
}

</style>  
</head>  
<body>  <!-- ===== DEMO BACKGROUND ===== -->  <div style="padding:100px 40px; color:#555; font-family:Cairo,sans-serif; direction:rtl; max-width:600px; margin:0 auto;">  
  <h2 style="color:#8B4513; margin-bottom:12px;">صفحة تجريبية</h2>  
  <p>هذا المحتوى للاختبار فقط. أيقونة القهوة ☕ تظهر أعلى يسار الصفحة — اضغط عليها لتفتح ماكينة القهوة الذكية AQX.</p>  
</div>  <!-- ===== زر الفتح ===== -->  <!-- في ملفاتك الحقيقية: غيّر right: 18px إلى left: 18px لأنه يكون أقصى يسار -->  <button id="cm-toggle" onclick="cmToggle()" title="ماكينة القهوة الذكية AQX" style="position:fixed;top:18px;left:18px;right:auto;z-index:77777;width:52px;height:52px;border-radius:14px;background:linear-gradient(145deg,#1a0a00,#3d1a00);border:2px solid #8B4513;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(139,69,19,0.5);font-size:24px;animation:cmPulseBtn 3s infinite;" title="ماكينة القهوة الذكية">☕</button>

<!-- ===== الأوفرلاي ===== -->  <div id="cm-overlay" onclick="cmClose()"></div>  <!-- ===== البطاقة الرئيسية ===== -->  <div id="cm-card">  
  <div class="cm-body">  <!-- زر الإغلاق -->  
<button id="cm-close" onclick="cmClose()">✕</button>  

<!-- رسم ماكينة القهوة -->  
<div class="cm-machine-art">  
  <svg width="120" height="110" viewBox="0 0 120 110" fill="none" xmlns="http://www.w3.org/2000/svg">  
    <!-- جسم الماكينة -->  
    <rect x="15" y="30" width="90" height="65" rx="10" fill="url(#machineGrad)" stroke="#8B4513" stroke-width="1.5"/>  
    <!-- لوح الأزرار -->  
    <rect x="22" y="36" width="76" height="28" rx="6" fill="rgba(0,0,0,0.4)" stroke="rgba(139,69,19,0.5)" stroke-width="1"/>  
    <!-- شاشة صغيرة -->  
    <rect x="26" y="40" width="42" height="18" rx="4" fill="#001a0a"/>  
    <text x="47" y="53" font-size="7" fill="#00FF88" text-anchor="middle" font-family="monospace">AQX v2.0</text>  
    <!-- أزرار -->  
    <circle cx="80" cy="44" r="4" fill="#FFD700" opacity="0.8"/>  
    <circle cx="92" cy="44" r="4" fill="#FF4444" opacity="0.8"/>  
    <circle cx="80" cy="56" r="4" fill="#00CDD9" opacity="0.8"/>  
    <circle cx="92" cy="56" r="4" fill="#8B4513" opacity="0.9"/>  
    <!-- رأس العصّارة -->  
    <rect x="44" y="68" width="32" height="8" rx="3" fill="#5D2E06" stroke="#8B4513" stroke-width="1"/>  
    <rect x="54" y="76" width="12" height="14" rx="2" fill="#3d1a00" stroke="#8B4513" stroke-width="1"/>  
    <!-- الكوب -->  
    <path d="M46 92 L50 105 L70 105 L74 92 Z" fill="url(#cupGrad)" stroke="#8B4513" stroke-width="1"/>  
    <ellipse cx="60" cy="92" rx="14" ry="3" fill="#5D2E06"/>  
    <!-- قهوة في الكوب -->  
    <ellipse cx="60" cy="92.5" rx="11" ry="2" fill="#3d1a00" opacity="0.8"/>  
    <!-- مقبض الكوب -->  
    <path d="M74 96 Q82 96 82 100 Q82 104 74 104" stroke="#8B4513" stroke-width="2" fill="none"/>  
    <!-- رأس الماكينة -->  
    <rect x="25" y="22" width="70" height="12" rx="5" fill="url(#topGrad)" stroke="#8B4513" stroke-width="1"/>  
    <!-- بخار SVG متحرك -->  
    <g opacity="0.7">  
      <line x1="52" y1="20" x2="50" y2="10" stroke="rgba(255,255,255,0.5)" stroke-width="1.5" stroke-linecap="round">  
        <animate attributeName="y2" values="10;2;10" dur="2s" repeatCount="indefinite"/>  
        <animate attributeName="opacity" values="0.7;0.1;0.7" dur="2s" repeatCount="indefinite"/>  
      </line>  
      <line x1="60" y1="20" x2="60" y2="8" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" stroke-linecap="round">  
        <animate attributeName="y2" values="8;0;8" dur="2.3s" repeatCount="indefinite"/>  
        <animate attributeName="opacity" values="0.6;0.1;0.6" dur="2.3s" repeatCount="indefinite"/>  
      </line>  
      <line x1="68" y1="20" x2="70" y2="10" stroke="rgba(255,255,255,0.5)" stroke-width="1.5" stroke-linecap="round">  
        <animate attributeName="y2" values="10;2;10" dur="1.8s" repeatCount="indefinite"/>  
        <animate attributeName="opacity" values="0.7;0.1;0.7" dur="1.8s" repeatCount="indefinite"/>  
      </line>  
    </g>  
    <!-- ضوء LED وهاج -->  
    <circle cx="80" cy="44" r="6" fill="rgba(255,215,0,0.15)">  
      <animate attributeName="r" values="4;7;4" dur="2s" repeatCount="indefinite"/>  
      <animate attributeName="opacity" values="0.3;0.0;0.3" dur="2s" repeatCount="indefinite"/>  
    </circle>  
    <defs>  
      <linearGradient id="machineGrad" x1="15" y1="30" x2="105" y2="95" gradientUnits="userSpaceOnUse">  
        <stop offset="0%" stop-color="#2D1200"/>  
        <stop offset="50%" stop-color="#1C0A00"/>  
        <stop offset="100%" stop-color="#0d0400"/>  
      </linearGradient>  
      <linearGradient id="topGrad" x1="25" y1="22" x2="95" y2="34" gradientUnits="userSpaceOnUse">  
        <stop offset="0%" stop-color="#5D2E06"/>  
        <stop offset="100%" stop-color="#3d1a00"/>  
      </linearGradient>  
      <linearGradient id="cupGrad" x1="46" y1="92" x2="74" y2="105" gradientUnits="userSpaceOnUse">  
        <stop offset="0%" stop-color="#8B6914"/>  
        <stop offset="100%" stop-color="#5D4010"/>  
      </linearGradient>  
    </defs>  
  </svg>  
</div>  

<!-- رأس البطاقة -->  
<div class="cm-header">  
  <div class="cm-title">☕ ماكينة القهوة الذكية AQX</div>  
  <div class="cm-subtitle">جرعة يومية من العبقرية والحظ والإبداع</div>  
</div>  

<!-- بخار -->  
<div class="cm-steam-wrap" style="margin-top:8px;">  
  <div class="cm-steam"></div>  
  <div class="cm-steam"></div>  
  <div class="cm-steam"></div>  
  <div class="cm-steam"></div>  
</div>  

<div class="cm-last-update" id="cm-last-update">⏱ آخر تحديث: الآن</div>  

<!-- ===== المحتوى ===== -->  
<div class="cm-content" id="cm-content">  

  <!-- 1. نسبة العبقرية -->  
  <div class="cm-item" id="cm-genius">  
    <div class="cm-item-label">🧠 نسبة العبقرية</div>  
    <div class="cm-item-value">  
      <span class="emoji-icon">🧠</span>  
      <span id="val-genius">—</span>%  
    </div>  
    <div class="cm-bar-wrap"><div class="cm-bar-fill bar-genius" id="bar-genius" style="width:0%"></div></div>  
  </div>  

  <!-- 2. مستوى الإبداع -->  
  <div class="cm-item" id="cm-create">  
    <div class="cm-item-label">🎨 مستوى الإبداع</div>  
    <div class="cm-item-value">  
      <span class="emoji-icon">🎨</span>  
      <span id="val-create">—</span>%  
    </div>  
